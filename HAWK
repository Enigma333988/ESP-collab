--[[
    HAWK: Horizontal auto-aim + auto-fire for nearest zombie
    Поведение:
    - Стреляет в направлении ближайшего зомби из Workspace.Zombies_Local
    - Вертикальная наводка игнорируется (только поворот по XZ)
    - Если зомби опустился ниже своей исходной высоты даже немного,
      он считается мёртвым и сразу игнорируется
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local VirtualInputManager = game:GetService("VirtualInputManager")

local LOCAL_PLAYER = Players.LocalPlayer
local ZOMBIES_FOLDER = Workspace:FindFirstChild("Zombies_Local") or Workspace:WaitForChild("Zombies_Local")

local FIRE_MOUSE_BUTTON = Enum.UserInputType.MouseButton1
local RETARGET_INTERVAL = 0.05
local FALL_DEAD_OFFSET = 0.8

local currentTarget = nil
local isFiring = false
local lastRetargetTime = 0
local zombieBaseY = {}

local function getCamera()
    return Workspace.CurrentCamera
end

local function getCharacter()
    return LOCAL_PLAYER.Character
end

local function getCharacterRoot()
    local character = getCharacter()
    if not character then
        return nil
    end

    return character:FindFirstChild("HumanoidRootPart")
end

local function getCharacterHumanoid()
    local character = getCharacter()
    if not character then
        return nil
    end

    return character:FindFirstChildOfClass("Humanoid")
end

local function getZombieHumanoid(model)
    for _, child in ipairs(model:GetChildren()) do
        if child:IsA("Humanoid") then
            return child
        end
    end
    return nil
end

local function getZombieAimPart(model)
    local root = model:FindFirstChild("HumanoidRootPart")
    if root and root:IsA("BasePart") then
        return root
    end

    local upperTorso = model:FindFirstChild("UpperTorso")
    if upperTorso and upperTorso:IsA("BasePart") then
        return upperTorso
    end

    local torso = model:FindFirstChild("Torso")
    if torso and torso:IsA("BasePart") then
        return torso
    end

    local head = model:FindFirstChild("Head")
    if head and head:IsA("BasePart") then
        return head
    end

    for _, child in ipairs(model:GetChildren()) do
        if child:IsA("BasePart") then
            return child
        end
    end

    return nil
end

local function hasDeadFlag(model)
    local deadFlag = model:FindFirstChild("Dead") or model:FindFirstChild("IsDead") or model:FindFirstChild("Died")
    if deadFlag and deadFlag:IsA("BoolValue") then
        return deadFlag.Value == true
    end

    return false
end

local function rememberZombieBaseY(model, aimPart)
    if zombieBaseY[model] == nil then
        zombieBaseY[model] = aimPart.Position.Y
    end
end

local function fellBelowBaseY(model, aimPart)
    rememberZombieBaseY(model, aimPart)
    return aimPart.Position.Y < (zombieBaseY[model] - FALL_DEAD_OFFSET)
end

local function isZombieAlive(model)
    if not model or not model.Parent then
        return false
    end

    local aimPart = getZombieAimPart(model)
    if not aimPart then
        return false
    end

    if hasDeadFlag(model) then
        return false
    end

    if fellBelowBaseY(model, aimPart) then
        return false
    end

    local humanoid = getZombieHumanoid(model)
    if humanoid then
        return humanoid.Health > 0 and humanoid:GetState() ~= Enum.HumanoidStateType.Dead
    end

    return true
end

local function getNearestAliveZombie()
    local playerRoot = getCharacterRoot()
    if not playerRoot then
        return nil
    end

    local nearestZombie = nil
    local nearestDistance = math.huge

    for _, zombie in ipairs(ZOMBIES_FOLDER:GetChildren()) do
        if zombie:IsA("Model") and isZombieAlive(zombie) then
            local aimPart = getZombieAimPart(zombie)
            local distance = (aimPart.Position - playerRoot.Position).Magnitude

            if distance < nearestDistance then
                nearestDistance = distance
                nearestZombie = zombie
            end
        end
    end

    return nearestZombie
end

local function startFiring()
    if isFiring then
        return
    end

    isFiring = true
    VirtualInputManager:SendMouseButtonEvent(0, 0, FIRE_MOUSE_BUTTON.Value, true, game, 0)
end

local function stopFiring()
    if not isFiring then
        return
    end

    isFiring = false
    VirtualInputManager:SendMouseButtonEvent(0, 0, FIRE_MOUSE_BUTTON.Value, false, game, 0)
end

local function aimHorizontallyToZombie(model)
    local playerRoot = getCharacterRoot()
    local aimPart = getZombieAimPart(model)
    local camera = getCamera()
    if not playerRoot or not aimPart or not camera then
        return
    end

    local flatTarget = Vector3.new(aimPart.Position.X, playerRoot.Position.Y, aimPart.Position.Z)

    playerRoot.CFrame = CFrame.lookAt(playerRoot.Position, flatTarget)

    local camOrigin = camera.CFrame.Position
    local camFlatTarget = Vector3.new(aimPart.Position.X, camOrigin.Y, aimPart.Position.Z)
    camera.CFrame = CFrame.lookAt(camOrigin, camFlatTarget)

    local humanoid = getCharacterHumanoid()
    if humanoid then
        humanoid.AutoRotate = false
    end
end

local function restoreCharacterAutoRotate()
    local humanoid = getCharacterHumanoid()
    if humanoid then
        humanoid.AutoRotate = true
    end
end

RunService.RenderStepped:Connect(function()
    local now = os.clock()

    if (not currentTarget) or (not isZombieAlive(currentTarget)) or (now - lastRetargetTime >= RETARGET_INTERVAL) then
        currentTarget = getNearestAliveZombie()
        lastRetargetTime = now
    end

    if currentTarget and isZombieAlive(currentTarget) then
        aimHorizontallyToZombie(currentTarget)
        startFiring()
    else
        currentTarget = nil
        restoreCharacterAutoRotate()
        stopFiring()
    end
end)

ZOMBIES_FOLDER.ChildRemoved:Connect(function(child)
    zombieBaseY[child] = nil

    if child == currentTarget then
        currentTarget = nil
        restoreCharacterAutoRotate()
        stopFiring()
    end
end)
