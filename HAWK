    state.inspectorEnabled = not state.inspectorEnabled
    infoToggle.Text = state.inspectorEnabled and "Инспектор: ВКЛ" or "Инспектор: ВЫКЛ"
    statusBar.Text = state.inspectorEnabled and "  Инспектор включен: кликните по объекту" or "  Инспектор выключен"
end)

tpToTarget.MouseButton1Click:Connect(function()
    local target = state.selectedObject
    if not target then
        statusBar.Text = "  Нет выбранного объекта"
        return
    end

    local destination
    if target:IsA("BasePart") then
        destination = target.CFrame
    elseif target:IsA("Model") then
        destination = target:GetPivot()
    end

    if destination then
        local root = getRootPart()
        root.CFrame = destination + Vector3.new(0, 4, 0)
        statusBar.Text = "  Телепорт выполнен к: " .. target.Name
    else
        statusBar.Text = "  Нельзя телепортироваться к этому типу объекта"
    end
end)

local function collectBananas3()
    local prefabs = Workspace:FindFirstChild("Prefabs")
    if not prefabs then
        return 0
    end

    local rootPart = getRootPart()
    local moved = 0

    for _, obj in ipairs(prefabs:GetChildren()) do
        if obj.Name == "Bananas3" and obj:IsA("MeshPart") then
            obj.CFrame = rootPart.CFrame
            moved += 1
        end
    end

    return moved
end

bananaToggle.MouseButton1Click:Connect(function()
    state.bananaEnabled = not state.bananaEnabled
    bananaToggle.Text = state.bananaEnabled and "Автосбор Bananas3: ВКЛ" or "Автосбор Bananas3: ВЫКЛ"
    statusBar.Text = state.bananaEnabled and "  Автосбор Bananas3 включен" or "  Автосбор Bananas3 выключен"
end)

bananaPulse.MouseButton1Click:Connect(function()
    local moved = collectBananas3()
    statusBar.Text = string.format("  Собрано за 1 раз: %d", moved)
end)

closeBtn.MouseButton1Click:Connect(function()
    clearAllEsp()
