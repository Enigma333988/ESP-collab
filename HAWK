--[[
HAWK Teleport GUI
- Paste text like:
  CFrame.new(-248.992, 8.430, 4.226) * CFrame.fromMatrix(...)
- Add multiple points to list.
- Teleport by clicking "TP".
- Window supports drag, minimize, and close.
- Close fully stops the script by destroying UI and disconnecting events.
]]

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
local playerGui = player:WaitForChild("PlayerGui")

local function getRootPart()
    local character = player.Character or player.CharacterAdded:Wait()
    return character:FindFirstChild("HumanoidRootPart") or character:WaitForChild("HumanoidRootPart")
end

local function parseTeleportText(raw)
    if type(raw) ~= "string" then
        return nil, "Текст не найден"
    end

    -- 1) Main supported format: CFrame.new(x, y, z)
    local x, y, z = raw:match("CFrame%.new%s*%(%s*([%-%d%.]+)%s*,%s*([%-%d%.]+)%s*,%s*([%-%d%.]+)%s*%)")
    if x and y and z then
        return CFrame.new(tonumber(x), tonumber(y), tonumber(z))
    end

    -- 2) Fallback format: x, y, z
    local fx, fy, fz = raw:match("^%s*([%-%d%.]+)%s*,%s*([%-%d%.]+)%s*,%s*([%-%d%.]+)%s*$")
    if fx and fy and fz then
        return CFrame.new(tonumber(fx), tonumber(fy), tonumber(fz))
    end

    return nil, "Не удалось прочитать координаты. Используй CFrame.new(x, y, z) или x, y, z"
end

