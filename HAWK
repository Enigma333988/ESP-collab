local function activateTab(name)
    for tabName, panel in pairs(panels) do
        panel.Visible = (tabName == name)
        local btn = tabButtons[tabName]
        if btn then
            btn.BackgroundColor3 = (tabName == name) and Color3.fromRGB(92, 136, 220) or Color3.fromRGB(47, 56, 74)
        end
    end
    activeTab = name
    statusBar.Text = "  Активная вкладка: " .. name
end

