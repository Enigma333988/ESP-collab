-- HAWK: лёгкий ESP для головы мальчиков (только надпись + дистанция)
-- LocalScript

local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")

local LocalPlayer = Players.LocalPlayer

local SETTINGS = {
    Enabled = true,
    TextColor = Color3.fromRGB(80, 190, 255),
    TextSize = 14,
    MaxDistance = 5000,
    UpdateInterval = 0.15,
    StudsOffset = Vector3.new(0, 0.9, 0),
}

local trackedHeads = {}
local updateAccumulator = 0

local function getLocalRoot()
    local character = LocalPlayer.Character
    if not character then
        return nil
    end

    return character:FindFirstChild("HumanoidRootPart")
end

local function isTargetHead(part)
    return part
        and part:IsDescendantOf(Workspace)
        and part:IsA("MeshPart")
        and part.Name == "Head"
        and part.Parent
        and part.Parent.Name == "Male"
end

local function detachHead(head)
    local gui = trackedHeads[head]
    if gui then
        gui:Destroy()
        trackedHeads[head] = nil
    end
end

local function createHeadLabel(head)
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "BoysHeadLabel"
    billboard.Size = UDim2.fromOffset(140, 24)
    billboard.StudsOffset = SETTINGS.StudsOffset
    billboard.AlwaysOnTop = true
    billboard.MaxDistance = SETTINGS.MaxDistance
    billboard.Adornee = head
    billboard.Parent = head

    local label = Instance.new("TextLabel")
    label.Name = "Distance"
    label.BackgroundTransparency = 1
    label.Size = UDim2.fromScale(1, 1)
    label.Font = Enum.Font.GothamBold
    label.TextColor3 = SETTINGS.TextColor
    label.TextSize = SETTINGS.TextSize
    label.TextStrokeTransparency = 0.15
    label.Text = "Head | --m"
    label.Parent = billboard

    trackedHeads[head] = billboard
end

local function attachHead(head)
    if trackedHeads[head] then
        return
    end

    createHeadLabel(head)
end

local function refreshHeadLabels()
    if not SETTINGS.Enabled then
        for head in pairs(trackedHeads) do
            detachHead(head)
        end
        return
    end

    local localRoot = getLocalRoot()

    for head, billboard in pairs(trackedHeads) do
        if not isTargetHead(head) then
            detachHead(head)
        else
            local label = billboard:FindFirstChild("Distance")
            if label then
                if localRoot then
                    local distance = (head.Position - localRoot.Position).Magnitude
                    label.Text = string.format("Head | %dm", math.floor(distance + 0.5))
                else
                    label.Text = "Head | --m"
                end
            end
        end
    end
end

for _, instance in ipairs(Workspace:GetDescendants()) do
    if isTargetHead(instance) then
        attachHead(instance)
    end
end

Workspace.DescendantAdded:Connect(function(instance)
    if isTargetHead(instance) and SETTINGS.Enabled then
        attachHead(instance)
    end
end)

Workspace.DescendantRemoving:Connect(function(instance)
    if trackedHeads[instance] then
        detachHead(instance)
    end
end)

RunService.Heartbeat:Connect(function(deltaTime)
    updateAccumulator += deltaTime
    if updateAccumulator < SETTINGS.UpdateInterval then
        return
    end

    updateAccumulator = 0
    refreshHeadLabels()
end)

refreshHeadLabels()
