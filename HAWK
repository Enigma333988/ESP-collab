-- HAWK: Ammo collector UI (toggle / minimize / close / drag)
-- Collects projectile parts (Shell/Bullet/etc.) and teleports them to the local player.

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")

local player = Players.LocalPlayer
if not player then
    return
end

local function getRootPart()
    local character = player.Character or player.CharacterAdded:Wait()
    return character:FindFirstChild("HumanoidRootPart") or character:WaitForChild("HumanoidRootPart", 5)
end

local collectorEnabled = false
local minimized = false
local conn
local addedConn
local removingConn

local ammoParts = {}

-- ВАЖНО: не используем "ammo" как keyword для имени,
-- чтобы не цеплять объекты вроде ammodepositpads.Part
local nameKeywords = {
    "shell", "bullet", "projectile", "round", "slug", "cartridge"
}

local function hasAmmoAncestor(instance)
    local current = instance.Parent
    while current do
        if current == workspace then
            break
        end

        if string.lower(current.Name) == "ammo" then
            return true
        end

        current = current.Parent
    end

    return false
end

local function isAmmoPart(instance)
    if not instance:IsA("BasePart") then
        return false
    end

    local ownName = string.lower(instance.Name)

    if hasAmmoAncestor(instance) then
        return true
    end

    for _, keyword in ipairs(nameKeywords) do
        if string.find(ownName, keyword, 1, true) then
            return true
        end
    end

    return false
end

local function trackIfAmmo(instance)
    if isAmmoPart(instance) then
        ammoParts[instance] = true
    end
end

local function untrack(instance)
    ammoParts[instance] = nil
end

local function rebuildAmmoCache()
    table.clear(ammoParts)

    for _, obj in ipairs(workspace:GetDescendants()) do
        if isAmmoPart(obj) then
            ammoParts[obj] = true
        end
    end
end

local function collectAmmoToPlayer()
    local hrp = getRootPart()
    if not hrp then
        return
    end

    local i = 0
    for obj in pairs(ammoParts) do
        if obj and obj.Parent and obj:IsDescendantOf(workspace) then
            i += 1

            local angle = i * 0.45
            local radius = 2 + (i % 6) * 0.35
            local offset = Vector3.new(math.cos(angle) * radius, 1 + (i % 3) * 0.2, math.sin(angle) * radius)

            obj.CFrame = hrp.CFrame + offset
            obj.AssemblyLinearVelocity = Vector3.zero
            obj.AssemblyAngularVelocity = Vector3.zero
        else
            ammoParts[obj] = nil
        end
    end
end

