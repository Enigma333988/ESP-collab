local function updateRadiusUI()
    if ui.radiusLabel then
        ui.radiusLabel.Text = string.format("Радиус захвата: %d", SETTINGS.CaptureRadius)
    end

    local alpha = (SETTINGS.CaptureRadius - SETTINGS.MinRadius) / (SETTINGS.MaxRadius - SETTINGS.MinRadius)
    if ui.sliderFill then
        ui.sliderFill.Size = UDim2.new(alpha, 0, 1, 0)
    end
    if ui.sliderKnob then
        ui.sliderKnob.Position = UDim2.new(alpha, 0, 0.5, 0)
    end

    if ui.captureCircle and Workspace.CurrentCamera then
        local cam = Workspace.CurrentCamera
        local center = cam.ViewportSize * 0.5
        local diameter = SETTINGS.CaptureRadius * 2
        ui.captureCircle.Size = UDim2.fromOffset(diameter, diameter)
        ui.captureCircle.Position = UDim2.fromOffset(center.X, center.Y)
        ui.captureCircle.Visible = SETTINGS.AssistEnabled
    end
end

local function setRadiusFromPixel(pixelX)
    local relative = math.clamp((pixelX - sliderBar.AbsolutePosition.X) / sliderBar.AbsoluteSize.X, 0, 1)
    SETTINGS.CaptureRadius = math.floor(SETTINGS.MinRadius + (SETTINGS.MaxRadius - SETTINGS.MinRadius) * relative + 0.5)
    updateRadiusUI()
end

sliderBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        state.draggingRadius = true
        setRadiusFromPixel(input.Position.X)
    end
end)

