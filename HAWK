    tpButton.Parent = row

    local tpCorner = Instance.new("UICorner")
    tpCorner.CornerRadius = UDim.new(0, 6)
    tpCorner.Parent = tpButton

    local removeButton = Instance.new("TextButton")
    removeButton.Size = UDim2.fromOffset(54, 30)
    removeButton.Position = UDim2.new(1, -58, 0.5, -15)
    removeButton.BackgroundColor3 = Color3.fromRGB(170, 68, 68)
    removeButton.Text = "DEL"
    removeButton.TextColor3 = Color3.fromRGB(255, 255, 255)
    removeButton.Font = Enum.Font.GothamBold
    removeButton.TextSize = 12
    removeButton.Parent = row

    local delCorner = Instance.new("UICorner")
    delCorner.CornerRadius = UDim.new(0, 6)
    delCorner.Parent = removeButton

    tpButton.MouseButton1Click:Connect(function()
        if state.destroyed then
            return
        end
        teleportTo(point.cframe)
        setStatus(string.format("Телепорт к точке #%d", index), false)
    end)

    removeButton.MouseButton1Click:Connect(function()
        if state.destroyed then
            return
        end

        table.remove(state.points, index)

        for _, child in ipairs(list:GetChildren()) do
            if child:IsA("Frame") then
                child:Destroy()
            end
        end

        for newIndex, p in ipairs(state.points) do
            createPointRow(newIndex, p)
        end

        setStatus("Точка удалена", false)
    end)
end

local function addPointFromInput()
    if state.destroyed then
        return
    end

    local text = input.Text
    local cf, err = parseTeleportText(text)
    if not cf then
        setStatus(err, true)
        return
    end

    local point = {
        cframe = cf,
        pos = cf.Position,
        raw = text,
    }

    table.insert(state.points, point)
    createPointRow(#state.points, point)
    setStatus(string.format("Добавлена точка #%d", #state.points), false)
end

addButton.MouseButton1Click:Connect(addPointFromInput)
input.FocusLost:Connect(function(enterPressed)
    if enterPressed then
        addPointFromInput()
    end
end)

local dragConnInputChanged
local dragConnInputEnded
local dragStart
local startPos
local dragging = false

local function endDrag()
    dragging = false
    if dragConnInputChanged then
        dragConnInputChanged:Disconnect()
        dragConnInputChanged = nil
    end
    if dragConnInputEnded then
        dragConnInputEnded:Disconnect()
        dragConnInputEnded = nil
    end
end

local function beginDrag(inputObject)
    dragging = true
    dragStart = inputObject.Position
    startPos = main.Position

    dragConnInputChanged = UserInputService.InputChanged:Connect(function(changed)
        if not dragging then
            return
        end
        if changed.UserInputType ~= Enum.UserInputType.MouseMovement and changed.UserInputType ~= Enum.UserInputType.Touch then
            return
        end
        local delta = changed.Position - dragStart
        main.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end)

    dragConnInputEnded = UserInputService.InputEnded:Connect(function(ended)
        if ended.UserInputType == Enum.UserInputType.MouseButton1 or ended.UserInputType == Enum.UserInputType.Touch then
            endDrag()
        end
    end)
end

table.insert(state.connections, topBar.InputBegan:Connect(function(inputObject)
    if inputObject.UserInputType == Enum.UserInputType.MouseButton1 or inputObject.UserInputType == Enum.UserInputType.Touch then
        beginDrag(inputObject)
    end
end))

table.insert(state.connections, minimizeButton.MouseButton1Click:Connect(function()
    state.minimized = not state.minimized
    content.Visible = not state.minimized
    main.Size = state.minimized and UDim2.fromOffset(480, 36) or UDim2.fromOffset(480, 360)
    minimizeButton.Text = state.minimized and "+" or "—"
end))

table.insert(state.connections, closeButton.MouseButton1Click:Connect(function()
    destroyScript()
end))

