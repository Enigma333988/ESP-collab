-- drag window (works in expanded and collapsed state)
local dragging = false
local dragStart
local startPos
local dragInput

topbar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = window.Position
        dragInput = input

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

topbar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if dragging and input == dragInput then
        local delta = input.Position - dragStart
        window.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = false
    end
end)

collapseBtn.MouseButton1Click:Connect(function()
    state.collapsed = not state.collapsed
    applyCollapsedState()
end)

bananaToggle.MouseButton1Click:Connect(function()
    state.bananaEnabled = not state.bananaEnabled
    bananaToggle.Text = state.bananaEnabled and "Автосбор Bananas3: ВКЛ" or "Автосбор Bananas3: ВЫКЛ"
    setStatus("Автосбор " .. (state.bananaEnabled and "включен" or "выключен"))
end)

bananaPulse.MouseButton1Click:Connect(function()
    local count = collectBananas3()
    setStatus("Собрано Bananas3: " .. count)
end)

closeBtn.MouseButton1Click:Connect(function()
    screenGui:Destroy()
end)

RunService.RenderStepped:Connect(function()
    if state.bananaEnabled then
        collectBananas3()
    end
end)

applyCollapsedState()
