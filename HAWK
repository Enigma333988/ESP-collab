-- HAWK meat teleporter script
-- Pulls meat3 mesh parts to the local player, including dinosaur/animal avatars.

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer
local playerGui = localPlayer:WaitForChild("PlayerGui")

local state = {
    enabled = false,
    closed = false,
    minimized = false,
    running = false,
}

local ROOT_CANDIDATES = {
    "HumanoidRootPart",
    "UpperTorso",
    "LowerTorso",
    "Torso",
    "Body",
    "Head",
}

local function getCharacter()
    return localPlayer.Character or localPlayer.CharacterAdded:Wait()
end

local function getRootPart()
    local character = getCharacter()

    for _, partName in ipairs(ROOT_CANDIDATES) do
        local part = character:FindFirstChild(partName)
        if part and part:IsA("BasePart") then
            return part
        end
    end

    if character.PrimaryPart and character.PrimaryPart:IsA("BasePart") then
        return character.PrimaryPart
    end

    for _, child in ipairs(character:GetChildren()) do
        if child:IsA("BasePart") then
            return child
        end
    end
end

local function getPlayerAnchorCFrame()
    local root = getRootPart()
    if root then
        return root.CFrame
    end

    local character = getCharacter()
    return character:GetPivot()
end

local function isMeatTarget(desc)
    return desc:IsA("MeshPart") and desc.Name == "meat3"
end

local function findTargets()
    local targets = {}

    for _, desc in ipairs(workspace:GetDescendants()) do
        if isMeatTarget(desc) then
            table.insert(targets, desc)
        end
    end

    table.sort(targets, function(a, b)
        return a:GetFullName() < b:GetFullName()
    end)

    return targets
end

local function moveMeatToPlayer(target, anchorCFrame, index)
    local row = math.floor((index - 1) / 3)
    local col = (index - 1) % 3
    local xOffset = (col - 1) * 1.8
    local yOffset = 2 + row * 1.1
    local zOffset = -3 - row * 0.4
    local targetCFrame = anchorCFrame * CFrame.new(xOffset, yOffset, zOffset)

    target.AssemblyLinearVelocity = Vector3.zero
    target.AssemblyAngularVelocity = Vector3.zero
    target.CFrame = targetCFrame
end

local function runLoop(statusLabel)
    if state.running then return end
    state.running = true

    task.spawn(function()
        while state.enabled and not state.closed do
            local anchorCFrame = getPlayerAnchorCFrame()
            local targets = findTargets()

            if not anchorCFrame then
                statusLabel.Text = "Статус: не удалось определить позицию персонажа/динозавра"
                task.wait(1)
            elseif #targets == 0 then
                statusLabel.Text = "Статус: мясо meat3 не найдено"
                task.wait(1)
            else
                local moved = 0

                for index, target in ipairs(targets) do
                    if not state.enabled or state.closed then
                        break
                    end

                    if target and target.Parent then
                        moveMeatToPlayer(target, anchorCFrame, index)
                        moved += 1
                        task.wait(0.05)
                    end
                end

                statusLabel.Text = string.format("Статус: притянуто кусков мяса: %d", moved)
                task.wait(0.2)
            end

            RunService.Heartbeat:Wait()
        end

        state.running = false
        if not state.closed then
            statusLabel.Text = "Статус: выключено"
        end
    end)
end

local function makeDraggable(topBar, frame)
    local dragging = false
    local dragInput
    local dragStart
    local startPos

    topBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    topBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

