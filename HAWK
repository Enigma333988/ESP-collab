-- HAWK auto-ammo teleport script
-- Teleports to 4 ammo platforms one by one, presses E, then returns to start position.

local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local RunService = game:GetService("RunService")

local localPlayer = Players.LocalPlayer
local playerGui = localPlayer:WaitForChild("PlayerGui")

local state = {
    enabled = false,
    closed = false,
    minimized = false,
    running = false,
}

local function getRoot()
    local character = localPlayer.Character or localPlayer.CharacterAdded:Wait()
    return character:WaitForChild("HumanoidRootPart")
end

local function findTargets()
    local targets = {}

    for _, desc in ipairs(workspace:GetDescendants()) do
        if desc:IsA("MeshPart") and desc.Name == "Cube.028_Cube.044" then
            local parentModel = desc.Parent
            local dispenserModel = parentModel and parentModel.Parent

            if parentModel and parentModel.Name == "Model" and dispenserModel and dispenserModel:IsA("Model") then
                local dispenserName = dispenserModel.Name
                if dispenserName:find("AmmoDispenser") then
                    table.insert(targets, desc)
                end
            end
        end
    end

    table.sort(targets, function(a, b)
        return a:GetFullName() < b:GetFullName()
    end)

    local result = {}
    for i = 1, math.min(4, #targets) do
        result[i] = targets[i]
    end

    return result
end

local function pressE()
    VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
    task.wait(0.08)
    VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
end

local function teleportTo(part)
    local root = getRoot()
    root.CFrame = part.CFrame + Vector3.new(0, 4, 0)
end

local function runLoop(statusLabel)
    if state.running then return end
    state.running = true

    task.spawn(function()
        while state.enabled and not state.closed do
            local root = getRoot()
            local startCFrame = root.CFrame

            local targets = findTargets()
            if #targets < 4 then
                statusLabel.Text = "Статус: нужно 4 платформы (найдено " .. tostring(#targets) .. ")"
                task.wait(1)
            else
                statusLabel.Text = "Статус: выполняю обход 4 платформ"
                for _, target in ipairs(targets) do
                    if not state.enabled or state.closed then
                        break
                    end

                    if target and target.Parent then
                        teleportTo(target)
                        task.wait(0.25)
                        pressE()
                        task.wait(0.35)
                    end
                end

                if state.enabled and not state.closed then
                    root.CFrame = startCFrame
                    statusLabel.Text = "Статус: цикл завершён, возврат в исходную точку"
                    task.wait(0.6)
                end
            end

            RunService.Heartbeat:Wait()
        end

        state.running = false
        if not state.closed then
            statusLabel.Text = "Статус: выключено"
        end
    end)
end

local function makeDraggable(topBar, frame)
    local dragging = false
    local dragInput
    local dragStart
    local startPos

    topBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position

            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)

    topBar.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement then
            dragInput = input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
end

