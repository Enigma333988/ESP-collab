local dragging = false
local dragInput
local dragStart
local startPos

topBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = main.Position

        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                dragging = false
            end
        end)
    end
end)

topBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
        dragInput = input
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if input == dragInput and dragging then
        local delta = input.Position - dragStart
        main.Position = UDim2.new(
            startPos.X.Scale,
            startPos.X.Offset + delta.X,
            startPos.Y.Scale,
            startPos.Y.Offset + delta.Y
        )
    end
end)

local function disconnectIfExists(connection)
    if connection then
        connection:Disconnect()
    end
end

local function setCollectorState(state)
    collectorEnabled = state

    if collectorEnabled then
        toggleBtn.Text = "Collector: ON"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(45, 130, 55)

        rebuildAmmoCache()

        disconnectIfExists(addedConn)
        disconnectIfExists(removingConn)
        disconnectIfExists(conn)

        addedConn = workspace.DescendantAdded:Connect(trackIfAmmo)
        removingConn = workspace.DescendantRemoving:Connect(untrack)


        local elapsed = 0
        conn = RunService.Heartbeat:Connect(function(dt)
            elapsed += dt
            if elapsed >= 1.0 then
                elapsed = 0
                rebuildAmmoCache()
            end

            collectAmmoToPlayer()
        end)
    else
        toggleBtn.Text = "Collector: OFF"
        toggleBtn.BackgroundColor3 = Color3.fromRGB(140, 45, 45)

        disconnectIfExists(conn)
        disconnectIfExists(addedConn)
        disconnectIfExists(removingConn)

        conn = nil
        addedConn = nil
        removingConn = nil
    end
end

toggleBtn.MouseButton1Click:Connect(function()
    setCollectorState(not collectorEnabled)
end)

btnMin.MouseButton1Click:Connect(function()
    minimized = not minimized
    body.Visible = not minimized
    main.Size = minimized and UDim2.fromOffset(320, 40) or UDim2.fromOffset(320, 160)
end)

btnClose.MouseButton1Click:Connect(function()
    setCollectorState(false)
    screenGui:Destroy()
end)
