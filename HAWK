--[[
    HAWK: Auto-aim + auto-fire for nearest zombie
    Поведение:
    - Ищет ближайшего живого зомби в Workspace.Zombies (включая тех, кто за спиной)
    - Как только цель выбрана, держит её в прицеле и стреляет до смерти цели
    - После смерти текущей цели сразу переключается на нового ближайшего зомби
]]

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")
local VirtualInputManager = game:GetService("VirtualInputManager")

local LOCAL_PLAYER = Players.LocalPlayer
local ZOMBIES_FOLDER = Workspace:WaitForChild("Zombies")

local HEAD_NAME = "Head"
local FIRE_MOUSE_BUTTON = Enum.UserInputType.MouseButton1

local currentTarget = nil
local isFiring = false

local function getCamera()
    return Workspace.CurrentCamera
end

local function getCharacterRoot()
    local character = LOCAL_PLAYER.Character
    if not character then
        return nil
    end

    return character:FindFirstChild("HumanoidRootPart")
end

local function getZombieHead(model)
    local head = model:FindFirstChild(HEAD_NAME)
    if head and head:IsA("BasePart") then
        return head
    end
    return nil
end

local function getZombieHumanoid(model)
    for _, child in ipairs(model:GetChildren()) do
        if child:IsA("Humanoid") then
            return child
        end
    end
    return nil
end

local function isZombieAlive(model)
    if not model or not model.Parent then
        return false
    end

    local head = getZombieHead(model)
    if not head then
        return false
    end

    local humanoid = getZombieHumanoid(model)
    if humanoid then
        return humanoid.Health > 0
    end

    return true
end

local function getNearestAliveZombie()
    local root = getCharacterRoot()
    if not root then
        return nil
    end

    local nearestZombie = nil
    local nearestDistance = math.huge

    for _, zombie in ipairs(ZOMBIES_FOLDER:GetChildren()) do
        if zombie:IsA("Model") and isZombieAlive(zombie) then
            local head = getZombieHead(zombie)
            local distance = (head.Position - root.Position).Magnitude

            if distance < nearestDistance then
                nearestDistance = distance
                nearestZombie = zombie
            end
        end
    end

    return nearestZombie
end

local function startFiring()
    if isFiring then
        return
    end

    isFiring = true
    VirtualInputManager:SendMouseButtonEvent(0, 0, FIRE_MOUSE_BUTTON.Value, true, game, 0)
end

local function stopFiring()
    if not isFiring then
        return
    end

    isFiring = false
    VirtualInputManager:SendMouseButtonEvent(0, 0, FIRE_MOUSE_BUTTON.Value, false, game, 0)
end

local function aimAtZombie(model)
    local camera = getCamera()
    local head = getZombieHead(model)
    if not camera or not head then
        return
    end

    local origin = camera.CFrame.Position
    camera.CFrame = CFrame.new(origin, head.Position)
end

RunService.RenderStepped:Connect(function()
    if currentTarget and not isZombieAlive(currentTarget) then
        currentTarget = nil
        stopFiring()
    end

    if not currentTarget then
        currentTarget = getNearestAliveZombie()
    end

    if currentTarget then
        aimAtZombie(currentTarget)
        startFiring()
    else
        stopFiring()
    end
end)

ZOMBIES_FOLDER.ChildRemoved:Connect(function(child)
    if child == currentTarget then
        currentTarget = nil
        stopFiring()
    end
end)
