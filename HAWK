end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then
        return
    end

    if input.UserInputType == Enum.UserInputType.MouseButton1 and state.inspectorEnabled then
        local mousePos = UserInputService:GetMouseLocation()
        local ray = Workspace.CurrentCamera:ViewportPointToRay(mousePos.X, mousePos.Y)

        local params = RaycastParams.new()
        params.FilterType = Enum.RaycastFilterType.Blacklist
        params.FilterDescendantsInstances = {getCharacter()}

        local result = Workspace:Raycast(ray.Origin, ray.Direction * 10000, params)
        if result and result.Instance then
            state.selectedObject = result.Instance
            setLog(objectReport(result.Instance))
            statusBar.Text = "  Выбран объект: " .. result.Instance:GetFullName()
        else
            statusBar.Text = "  Объект не найден под курсором"
        end
    end
end)

Players.PlayerRemoving:Connect(function(player)
    clearEspForPlayer(player)
end)

RunService.RenderStepped:Connect(function()
    -- ESP
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer then
            ensureEsp(player)
        end
    end

    -- Bananas3 Auto Collect
    if state.bananaEnabled then
        collectBananas3()
    end
end)

