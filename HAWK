tpToTarget.MouseButton1Click:Connect(function()
    local target = state.selectedObject
    if not target then
        setStatus("Нет выбранного объекта")
        return
    end

    local destination
    if target:IsA("BasePart") then
        destination = target.CFrame
    elseif target:IsA("Model") then
        destination = target:GetPivot()
    end

    local root = getRootPart(getCharacter(LocalPlayer))
    if root and destination then
        root.CFrame = destination + Vector3.new(0, 4, 0)
        setStatus("Телепорт выполнен к: " .. target.Name)
    else
        setStatus("Нельзя телепортироваться к этому объекту")
    end
end)

copyCamXYZ.MouseButton1Click:Connect(function()
    local cam = Workspace.CurrentCamera
    if not cam then
        setStatus("Камера недоступна")
        return
    end

    local cf = cam.CFrame
    local text = string.format(
        "CFrame.new(%.3f, %.3f, %.3f) * CFrame.fromMatrix(Vector3.zero, Vector3.new(%.6f, %.6f, %.6f), Vector3.new(%.6f, %.6f, %.6f), Vector3.new(%.6f, %.6f, %.6f))",
        cf.Position.X, cf.Position.Y, cf.Position.Z,
        cf.XVector.X, cf.XVector.Y, cf.XVector.Z,
        cf.YVector.X, cf.YVector.Y, cf.YVector.Z,
        cf.ZVector.X, cf.ZVector.Y, cf.ZVector.Z
    )

    local copied = false
    if typeof(setclipboard) == "function" then
        setclipboard(text)
        copied = true
    elseif typeof(toclipboard) == "function" then
        toclipboard(text)
        copied = true
    elseif typeof(clipboard_set) == "function" then
        clipboard_set(text)
        copied = true
    end

    setLog(text .. "\n\n" .. (copied and "Скопировано в буфер." or "Буфер недоступен, скопируйте вручную."))
    setStatus("Camera CFrame обновлён")
end)

